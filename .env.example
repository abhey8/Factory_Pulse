# Required for non-Docker runs.
# Use this local value if MongoDB is running on your machine.
# For MongoDB Atlas, replace the full value with your Atlas connection string.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>

# Safe local default. Change only if port 3000 is already in use.
PORT=3000

# Safe local default for this backend.
NODE_ENV=development

# Allowed browser origin for a future separate frontend.
# Keep "*" for local assessment/demo, or set e.g. "http://localhost:5173".
CORS_ORIGIN="*"
