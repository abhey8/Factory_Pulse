{
  "name": "factory-productivity-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack manufacturing productivity dashboard powered by AI CCTV events.",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:backend": "tsx watch src/server.ts",
    "dev:frontend": "npm run dev --prefix frontend",
    "frontend:install": "npm install --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "backend:build": "npm run clean && tsc",
    "build": "npm run frontend:build && npm run backend:build",
    "start": "node dist/src/server.js",
    "deploy:start": "npm run seed:if-empty && npm run start",
    "docker:start": "npm run seed:if-empty && npm run start",
    "seed": "tsx scripts/seed.ts",
    "seed:prod": "node dist/scripts/seed.js",
    "seed:if-empty": "node dist/scripts/seed-if-empty.js",
    "test": "vitest run"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "mongodb-memory-server": "^10.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
